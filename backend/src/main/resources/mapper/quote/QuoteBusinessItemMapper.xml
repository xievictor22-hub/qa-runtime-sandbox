<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mogo.project.modules.quote.domain.order.mapper.QuoteBusinessItemMapper">

    <resultMap id="BaseResultMap" type="com.mogo.project.modules.quote.domain.order.entity.QuoteBusinessItem">
        <id column="id" property="id" />
        <result column="quote_id" property="quoteId" />
        <result column="detail_id" property="detailId" />
        <result column="business_version" property="businessVersion" />
        <result column="factory_sales_adjust_amount" property="factorySalesAdjustAmount" />
        <result column="factory_cost_unit_price" property="factoryCostUnitPrice" />
        <result column="factory_discounts" property="factoryDiscounts" />
        <result column="factory_unit_price" property="factoryUnitPrice" />
        <result column="factory_total" property="factoryTotal" />
        <result column="factory_profit" property="factoryProfit" />
        <result column="factory_profit_rate" property="factoryProfitRate" />
        <result column="customer_factory_total" property="customerFactoryTotal" />
        <result column="adjusted_factory_profit_amount" property="adjustedFactoryProfitAmount" />
        <result column="adjusted_factory_profit_rate" property="adjustedFactoryProfitRate" />
        <result column="install_sales_adjust_amount" property="installSalesAdjustAmount" />
        <result column="install_cost_unit_price" property="installCostUnitPrice" />
        <result column="install_discounts" property="installDiscounts" />
        <result column="install_unit_price" property="installUnitPrice" />
        <result column="install_total" property="installTotal" />
        <result column="install_profit" property="installProfit" />
        <result column="install_profit_rate" property="installProfitRate" />
        <result column="customer_install_total" property="customerInstallTotal" />
        <result column="adjusted_install_profit_amount" property="adjustedInstallProfitAmount" />
        <result column="adjusted_install_profit_rate" property="adjustedInstallProfitRate" />
        <result column="sales_unit_price" property="salesUnitPrice" />
        <result column="sales_point" property="salesPoint" />
        <result column="sales_discount" property="salesDiscount" />
        <result column="sales_discounted_unit_price" property="salesDiscountedUnitPrice" />
        <result column="sales_total" property="salesTotal" />
        <result column="sales_profit" property="salesProfit" />
        <result column="customer_unit_price" property="customerUnitPrice" />
        <result column="sales_unit_adjust_amount" property="salesUnitAdjustAmount" />
        <result column="customer_total_price" property="customerTotalPrice" />
        <result column="lock_status" property="lockStatus" />
        <result column="remark" property="remark" />
        <result column="create_time" property="createTime" />
        <result column="update_time" property="updateTime" />

        <result column="product_name" property="productName" />
        <result column="spec" property="spec" />
        <result column="unit" property="unit" />
        <result column="quantity" property="quantity" />
    </resultMap>

    <select id="selectBusinessList" resultMap="BaseResultMap">
        SELECT
        b.*,
        d.product_name,
        d.spec,
        d.unit,
        d.quantity
        FROM quote_business_item b
        LEFT JOIN quote_detail d ON b.detail_id = d.id
        WHERE b.quote_id = #{quoteId}
        AND b.business_version = #{version}
        ORDER BY d.row_num ASC
    </select>

</mapper>
